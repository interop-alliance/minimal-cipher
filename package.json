{
  "name": "@interop/minimal-cipher",
  "version": "7.6.2",
  "description": "Minimal encryption/decryption JWE library.",
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./algorithms": {
      "types": "./dist/algorithms/index.d.ts",
      "react-native": "./dist/algorithms/index.js",
      "import": "./dist/algorithms/index.js",
      "default": "./dist/algorithms/index.js"
    }
  },
  "module": "dist/index.js",
  "browser": {
    "./dist/algorithms/c20p.js": "./dist/algorithms/c20p-browser.js",
    "./dist/algorithms/x25519-helper.js": "./dist/algorithms/x25519-helper-browser.js"
  },
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.md\"",
    "lint": "eslint src test && pnpm run typecheck",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run fix && pnpm run lint && pnpm run test:node && pnpm run test:browser",
    "test:browser": "playwright test",
    "test:node": "vitest run",
    "typecheck": "tsc -p tsconfig.dev.json --noEmit",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@interop/data-integrity-core": "^8.3.0",
    "@interop/ecdsa-multikey": "^2.3.3",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@stablelib/chacha": "^2.0.1",
    "@stablelib/chacha20poly1305": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@interop/did-io": "^4.1.0",
    "@interop/did-method-key": "^7.3.4",
    "@interop/ed25519-verification-key": "^8.0.3",
    "@interop/x25519-key-agreement-key": "^5.2.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/interop-alliance/minimal-cipher"
  },
  "keywords": [
    "cipher",
    "encryption",
    "decryption",
    "jwe",
    "cwe",
    "ChaCha20Poly1305",
    "XChaCha20Poly1305",
    "AES-GCM"
  ],
  "author": {
    "name": "Digital Bazaar, Inc.",
    "email": "support@digitalbazaar.com",
    "url": "https://digitalbazaar.com/"
  },
  "bugs": {
    "url": "https://github.com/interop-alliance/minimal-cipher/issues"
  },
  "homepage": "https://github.com/interop-alliance/minimal-cipher",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0"
  }
}
